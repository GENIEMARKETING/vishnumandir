{
  "kind": "collectionType",
  "collectionName": "board_members",
  "info": {
    "singularName": "board-member",
    "pluralName": "board-members",
    "displayName": "Board Member",
    "description": "Board of Trustees members with role, tier, and optional photo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true
    },
    "tier": {
      "type": "enumeration",
      "enum": ["President", "Executive", "Director"],
      "required": true,
      "default": "Director"
    },
    "bio": {
      "type": "text"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "displayOrder": {
      "type": "integer",
      "default": 99
    }
  }
}
